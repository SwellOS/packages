pkg_fetch() {
    fetch_url "$(cat sources)"
}

pkg_unpack() {
    unpack wireplumber-*.tar.bz2
}

pkg_build() {
    mkdir -p build && cd build

    meson setup .. \
        --prefix=/usr \
        --buildtype=release \
        -Ddocs=disabled \
        -Dsystemd=disabled \
        -Dsystemd-user-service=disabled

    ninja
}

pkg_install() {
    cd build
    DESTDIR="$DESTDIR" ninja install
}
