pkg_fetch() {
    fetch_url "$(cat sources)"
}

pkg_unpack() {
    unpack v*.tar.gz
    mv vim-* vim
}

pkg_build() {
    cd vim

    echo '#define SYS_VIMRC_FILE "/etc/vimrc"' > src/feature.h

    ./configure --prefix=/usr \
        --enable-multibyte \
        --with-tlib=ncurses

    make -j$(nproc)
}

pkg_install() {
    cd vim
    make DESTDIR="$DESTDIR" install

    ln -sfv vim "$DESTDIR/usr/bin/vi"
    mkdir -p "$DESTDIR/etc"
    cat > "$DESTDIR/etc/vimrc" << 'VIMRC'
" SwellOS default vimrc
syntax on
set number
set tabstop=4
set shiftwidth=4
set expandtab
VIMRC
}
