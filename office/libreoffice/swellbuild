pkg_fetch() {
    fetch_url "$(cat sources)"
}

pkg_unpack() {
    unpack libreoffice-*.tar.xz
    mv libreoffice-* libreoffice
}

pkg_build() {
    cd libreoffice

    ./autogen.sh --prefix=/usr \
        --disable-dependency-tracking \
        --enable-release-build \
        --enable-kde5=no \
        --enable-gtk3 \
        --disable-qt5 \
        --disable-qt6 \
        --without-java \
        --without-help \
        --without-doxygen

    make -j$(nproc)
}

pkg_install() {
    cd libreoffice
    make DESTDIR="$DESTDIR" install
}
