pkg_fetch() {
    fetch_url "$(cat sources)"
}

pkg_unpack() {
    unpack pipewire-*.tar.bz2
}

pkg_build() {
    mkdir -p build && cd build

    meson setup .. \
        --prefix=/usr \
        --buildtype=release \
        -Ddocs=disabled \
        -Dman=disabled \
        -Dtests=disabled \
        -Dexamples=disabled \
        -Dpipewire-jack=disabled \
        -Dpipewire-vulkan=disabled \
        -Dsession-managers=wireplumber

    ninja
}

pkg_install() {
    cd build
    DESTDIR="$DESTDIR" ninja install
}
