pkg_fetch() {
    fetch_url "$(cat sources)"
}

pkg_unpack() {
    unpack sed-*.tar.xz
}

pkg_build() {
    ./configure --prefix=/usr
    make -j$(nproc)
    make html
}

pkg_install() {
    make DESTDIR="$DESTDIR" install
    install -d -m755 "$DESTDIR/usr/share/doc/sed-4.9"
    install -m644 doc/sed.html "$DESTDIR/usr/share/doc/sed-4.9"
}
