pkg_fetch() {
    fetch_url "$(cat sources)"
}

pkg_unpack() {
    unpack nano-*.tar.xz
}

pkg_build() {
    ./configure --prefix=/usr
    make -j$(nproc)
}

pkg_install() {
    make DESTDIR="$DESTDIR" install

    mkdir -p "$DESTDIR/etc"
    cat > "$DESTDIR/etc/nanorc" << 'NANORC'
set tabsize 4
set linenumbers
set constantshow
NANORC
}
