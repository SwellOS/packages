pkg_fetch() {
    fetch_url "$(cat sources)"
}

pkg_unpack() {
    unpack xorg-server-*.tar.xz
}

pkg_build() {
    ./configure --prefix=/usr \
        --sysconfdir=/etc \
        --disable-static \
        --enable-glamor \
        --enable-suid-wrapper \
        --with-xkb-output=/var/lib/xkb

    make -j$(nproc)
}

pkg_install() {
    make DESTDIR="$DESTDIR" install
}
