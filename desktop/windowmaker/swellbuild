pkg_fetch() {
    fetch_url "$(cat sources)"
}

pkg_unpack() {
    unpack wmaker-*.tar.gz
    mv wmaker-* wmaker
}

pkg_build() {
    cd wmaker
    ./autogen.sh
    ./configure --prefix=/usr
    make -j$(nproc)
}

pkg_install() {
    cd wmaker
    make DESTDIR="$DESTDIR" install

    # Default config
    mkdir -p "$DESTDIR/etc/GNUstep/Defaults"
    cat > "$DESTDIR/etc/GNUstep/Defaults/WindowMaker" << 'CONF'
{
    DisplayName = "SwellOS";
    AutoFocus = Yes;
    Dock = ();
}
CONF
}
