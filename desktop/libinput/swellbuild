pkg_fetch() {
    fetch_url "$(cat sources)"
}

pkg_unpack() {
    unpack libinput-*.tar.xz
}

pkg_build() {
    mkdir -p build && cd build

    meson setup .. \
        --prefix=/usr \
        --buildtype=release \
        -Ddocumentation=disabled \
        -Dtests=disabled \
        -Ddebug-gui=disabled \
        -Dlibwacom=disabled

    ninja
}

pkg_install() {
    cd build
    DESTDIR="$DESTDIR" ninja install
}
