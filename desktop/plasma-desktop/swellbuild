pkg_fetch() {
    fetch_url "$(cat sources)"
}

pkg_unpack() {
    unpack plasma-*.tar.xz
}

pkg_build() {
    mkdir -p build && cd build

    cmake .. \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_TESTING=OFF \
        -DWITH_X11=OFF \
        -DWITH_WAYLAND=ON \
        -DBUILD_doc=OFF

    make -j$(nproc)
}

pkg_install() {
    cd build
    make DESTDIR="$DESTDIR" install

    # SDDM runit service
    mkdir -p "$DESTDIR/etc/sv/sddm"
    cat > "$DESTDIR/etc/sv/sddm/run" << 'RUN'
#!/bin/sh
exec /usr/bin/sddm
RUN
    chmod +x "$DESTDIR/etc/sv/sddm/run"
}
