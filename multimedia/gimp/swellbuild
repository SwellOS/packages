pkg_fetch() {
    fetch_url "$(cat sources)"
}

pkg_unpack() {
    unpack gimp-*.tar.xz
}

pkg_build() {
    mkdir -p build && cd build

    meson setup .. \
        --prefix=/usr \
        --buildtype=release \
        -Dbug-report-url=https://github.com/SwellOS/swellos/issues \
        -Dcheck-update=false

    ninja
}

pkg_install() {
    cd build
    DESTDIR="$DESTDIR" ninja install
}
