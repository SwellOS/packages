pkg_fetch() {
    fetch_url "$(cat sources)"
}

pkg_unpack() {
    unpack wine-*.tar.xz
}

pkg_build() {
    mkdir -p build && cd build

    ../configure --prefix=/usr \
        --enable-win64 \
        --disable-tests

    make -j$(nproc)
}

pkg_install() {
    cd build
    make DESTDIR="$DESTDIR" install
}
