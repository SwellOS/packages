pkg_fetch() {
    fetch_url "$(cat sources)"
}

pkg_unpack() {
    unpack Python-*.tar.xz
}

pkg_build() {
    ./configure --prefix=/usr \
        --enable-shared \
        --with-system-expat \
        --with-system-ffi \
        --enable-optimizations

    make -j$(nproc)
}

pkg_install() {
    make DESTDIR="$DESTDIR" install
}
